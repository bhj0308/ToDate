# Copy to .env and fill in. Defaults (in app/config.py) are dev-friendly.

ENVIRONMENT=development

# Dev default is SQLite (no infra needed). Production per ADR-0002:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/todate
DATABASE_URL=sqlite+aiosqlite:///./todate_dev.db

# CHANGE IN PRODUCTION — used to sign JWT access/refresh tokens (ADR-0001).
JWT_SECRET=dev-only-insecure-secret-change-me
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
OTP_TTL_SECONDS=300
